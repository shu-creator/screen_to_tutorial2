# Core
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@127.0.0.1:3306/tutorialgen
JWT_SECRET=replace-with-at-least-32-characters
OWNER_OPEN_ID=

# Auth mode: none | oauth
AUTH_MODE=none
# Production safety override for AUTH_MODE=none (not recommended)
ALLOW_UNSAFE_AUTH_MODE_NONE=false
DEV_USER_OPEN_ID=local-dev-user
DEV_USER_NAME=Local Dev User
DEV_USER_EMAIL=dev@example.com

# OAuth (required when AUTH_MODE=oauth)
OAUTH_SERVER_URL=https://oauth.example.com
VITE_OAUTH_PORTAL_URL=https://oauth-portal.example.com
VITE_APP_ID=your-app-id
VITE_AUTH_MODE=none

# LLM
# AUTHORING_PROVIDER: llm | codex_app_server
AUTHORING_PROVIDER=llm
# Optional Codex model override for AUTHORING_PROVIDER=codex_app_server.
# When set, app-server is launched with -c model=<CODEX_MODEL> and the value is
# included in the authoring cache key. Leave empty to use the Codex CLI default
# and disable authoring cache for Codex App Server runs.
CODEX_MODEL=
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_KEY=

# TTS
# TTS_PROVIDER accepts openai | gemini. TTS_PROVIDER=none is not supported yet;
# pipeline:generate does not synthesize TTS in the Codex authoring experiment.
TTS_PROVIDER=openai
TTS_MODEL=gpt-4o-mini-tts
TTS_API_KEY=

# ASR / OCR
ASR_PROVIDER=none
ASR_MODEL=whisper-1
# OCR_PROVIDER: none | llm | engine
#   engine = ローカルOCRエンジン（scripts/ocr_server.py: PaddleOCR→Tesseractの順に自動選択。
#   どちらも無い環境ではLLM-OCRへ自動フォールバック）。コスト・速度・座標精度で推奨
OCR_PROVIDER=llm
# 発話は操作に先行するため、各操作のtranscript参照ウィンドウを前方に広げる（ms）
ASR_LEAD_MS=3000

# Pipeline cache / frame boundary tuning
PIPELINE_CACHE_DIR=./data/cache
FRAME_DEDUPE_HASH_DISTANCE=6

# Evidence extraction (Phase 1)
# 一様サンプリングのfps。上げると高速操作の取りこぼしが減るが処理が重くなる
EVIDENCE_SAMPLE_FPS=4
# 遷移開始/終了のピクセル変化率閾値。1文字タイピング（約0.07%）を検出するため
# highは0.0007未満にすること。pixelThreshold=24が圧縮ノイズを除去する
EVIDENCE_DIFF_HIGH=0.0004
EVIDENCE_DIFF_LOW=0.00015
EVIDENCE_STABLE_FRAMES=2
# この時間以内の安定ギャップ+近接bboxの変化を1操作に合体（遅いタイピング対策）
EVIDENCE_COALESCE_MAX_GAP_MS=1000

# Clip-based video (Phase 4)
# クリップの前後パディングと長さ上限。上限超過時は末尾（操作の結果）を残して切り詰める
CLIP_PAD_BEFORE_MS=500
CLIP_PAD_AFTER_MS=800
CLIP_MAX_DURATION_S=20
# タイトルカード用フォント（未指定時はIPAゴシック等の既知パスを自動探索。
# 見つからない環境ではイントロ/アウトロをスキップ）
# SLIDE_FONT_FILE=/usr/share/fonts/opentype/ipafont-gothic/ipag.ttf

# Storage
STORAGE_DIR=./data/storage

# Slide template preset: default | training
SLIDE_PRESET=default

# Slide ROI tuning (used by training preset)
SLIDE_ROI_MIN_AREA_RATIO=0.015
SLIDE_ROI_MAX_AREA_RATIO=0.65
SLIDE_ROI_PADDING_RATIO=0.15
SLIDE_ROI_MIN_CROP_WIDTH_PX=900
SLIDE_SPOTLIGHT_OPACITY=0.35
